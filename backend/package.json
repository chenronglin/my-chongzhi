    "db:seed": "bun run src/database/seed.ts"
  },
  "dependencies": {
    "@elysiajs/jwt": "^1.4.1",
    "elysia": "^1.4.28"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/bun": "^1.3.11",
    "typescript": "^5.9.3"
  }
}
